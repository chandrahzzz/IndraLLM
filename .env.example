# Copy to .env and fill in. Never commit .env.
# Everything below is FREE-tier.

# Google AI Studio (free) -> https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# HuggingFace (free) -> https://huggingface.co/settings/tokens
HF_TOKEN=

# Reddit (free; create app at https://www.reddit.com/prefs/apps, type=script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=IndraLLM research script by u/YOUR_USERNAME

# Weights & Biases (optional)
WANDB_API_KEY=
